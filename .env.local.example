# Supabase (same project as treinos-web)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Secret (should match treinos-web or be separate)
JWT_SECRET=your-very-long-random-secret-at-least-32-chars

# Admin access: comma-separated list of emails that bypass user_type check
ADMIN_EMAILS=admin@example.com,another@example.com

# Cloudflare R2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=your-bucket-name
# URL pública do bucket R2 (sem barra no final) — converte r2://bucket/key para https://
# Mesmo valor do treinos-web: R2_PUBLIC_BASE_URL
R2_PUBLIC_BASE_URL=https://your-custom-domain.com
