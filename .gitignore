# See https://help.github.com/articles/ignoring-files/

# --- Dependencies ---
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js / build ---
/.next/
/out/
/build
/dist
*.tsbuildinfo

# --- Environment & secrets (never commit) ---
.env
.env.*
!.env.example
!.env*.example
!.env.local.example

# Keys, certs, credentials
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
credentials.json
service-account*.json
**/secrets/
**/*.secret
**/*.secrets

# --- Logs & debug ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
logs/

# --- Testing ---
/coverage
.nyc_output

# --- Deploy / infra local ---
.vercel
.turbo
.netlify

# --- Supabase CLI (local) ---
.supabase/

# --- IDE & OS ---
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo
*~

# --- TypeScript (generated by Next) ---
next-env.d.ts
